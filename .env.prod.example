# =============================================================================
# COMPANY TEMPLATE - Production Environment Configuration
# =============================================================================
# Copy this file to .env.prod and update all values before deploying.
#
# Usage examples:
# - Runtime scripts: NODE_ENV=production bun <command>
# - Docker Compose: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_DB=suba_app
POSTGRES_USER=suba
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://suba:replace-with-strong-password@suba-db:5432/suba_app

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
SERVER_PORT=3000

# -----------------------------------------------------------------------------
# Better Auth Configuration
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-with-a-secure-random-string-at-least-32-chars
BETTER_AUTH_URL=https://api.yourdomain.com

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Frontend Configuration (Vite)
# -----------------------------------------------------------------------------
VITE_SERVER_URL=https://api.yourdomain.com
VITE_FRONTEND_URL=https://yourdomain.com
VITE_SITE_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# Site Branding (Server-side SSR)
# -----------------------------------------------------------------------------
SITE_NAME=Your Company
SITE_TITLE=Your Company | Software Engineering & Digital Innovation
SITE_DESCRIPTION=We craft intelligent software platforms and digital products.
TWITTER_HANDLE=@yourcompany

# -----------------------------------------------------------------------------
# Rate Limiting & Security (Optional - defaults shown)
# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=600
# BODY_LIMIT_BYTES=10485760
# UPLOAD_MAX_BYTES=10485760
# GALLERY_UPLOAD_MAX_BYTES=83886080
