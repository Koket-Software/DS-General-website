# =============================================================================
# DS GENERAL PLC - Production Environment Configuration
# =============================================================================
# Copy this file to `.env` for VPS deploys, or to `.env.prod` for local
# production-style runs, then update all values before deploying.
#
# Usage examples:
# - Runtime scripts: NODE_ENV=production bun <command>
# - Docker Compose: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_DB=ds_general
POSTGRES_USER=ds_general
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://ds_general:replace-with-strong-password@ds-general-db:5432/ds_general

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
SERVER_PORT=3000

# -----------------------------------------------------------------------------
# Better Auth Configuration
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-with-a-secure-random-string-at-least-32-chars
BETTER_AUTH_URL=https://dsgeneralplc.com

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://dsgeneralplc.com,https://www.dsgeneralplc.com

# -----------------------------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# -----------------------------------------------------------------------------
# Frontend Configuration (Vite)
# -----------------------------------------------------------------------------
VITE_SERVER_URL=https://dsgeneralplc.com
VITE_FRONTEND_URL=https://dsgeneralplc.com
VITE_SITE_URL=https://dsgeneralplc.com

# -----------------------------------------------------------------------------
# Site Branding (Server-side SSR)
# -----------------------------------------------------------------------------
SITE_NAME=DS General PLC
SITE_URL=https://dsgeneralplc.com
SITE_TITLE=DS General PLC | We're Building the Future
SITE_DESCRIPTION=DS General PLC delivers reliable engineering, trading, and operational solutions for high-impact business sectors in Ethiopia.
TWITTER_HANDLE=@dsgeneralplc
SITE_LOCALE=en_US
THEME_COLOR=#4962E1
OG_DEFAULT_PATH=/og_image_ds.webp
BRAND_PRIMARY=#4962E1
BRAND_SECONDARY=#1D1D1D
BRAND_ACCENT=#F6F7FD
SITE_LOGO_PATH=/favicon.ico
SITE_KEYWORDS=ds general plc,ethiopia business solutions,engineering services,industrial solutions,trading services,general contracting,sourcing and logistics

# Optional web overrides (used by Vite client runtime)
VITE_SITE_NAME=DS General PLC
VITE_SITE_TITLE=DS General PLC | We're Building the Future
VITE_SITE_DESCRIPTION=DS General PLC delivers reliable engineering, trading, and operational solutions for high-impact business sectors in Ethiopia.
VITE_TWITTER_HANDLE=@dsgeneralplc
VITE_SITE_LOCALE=en_US
VITE_THEME_COLOR=#4962E1
VITE_OG_DEFAULT_PATH=/og_image_ds.webp
VITE_BRAND_PRIMARY=#4962E1
VITE_BRAND_SECONDARY=#1D1D1D
VITE_BRAND_ACCENT=#F6F7FD
VITE_SITE_LOGO_PATH=/favicon.ico
VITE_SITE_KEYWORDS=ds general plc,ethiopia business solutions,engineering services,industrial solutions,trading services,general contracting,sourcing and logistics

# -----------------------------------------------------------------------------
# VPS / Reverse Proxy
# -----------------------------------------------------------------------------
PROXY_NETWORK=replace-with-existing-npm-network-name

# -----------------------------------------------------------------------------
# Rate Limiting & Security (Optional - defaults shown)
# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=600
# BODY_LIMIT_BYTES=209715200
# UPLOAD_MAX_BYTES=209715200
# GALLERY_UPLOAD_MAX_BYTES=209715200
